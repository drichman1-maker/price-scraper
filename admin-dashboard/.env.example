# Copy to .env and fill in your values

# Admin API Key (for write operations)
ADMIN_API_KEY=your-secret-admin-key

# Backend URLs
THERESMAC_API_URL=https://theresmac-backend.fly.dev
GPUDRIP_API_URL=https://gpudrip-backend.fly.dev

# Backend API Keys
THERESMAC_API_KEY=your-api-key
GPUDRIP_API_KEY=your-api-key

# Port (default: 3001)
PORT=3001